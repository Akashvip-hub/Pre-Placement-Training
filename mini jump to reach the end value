import collections
class Solution(object):
    def minJumps(self, nums):
        n = len(nums)
        if n == 1: return 0
        
        max_val = max(nums)
        spf = list(range(max_val + 1))
        for i in range(2, int(max_val**0.5) + 1):
            if spf[i] == i:
                for j in range(i*i, max_val + 1, i):
                    if spf[j] == j:
                        spf[j] = i
        
        def is_prime(x):
            return x > 1 and spf[x] == x

        bucket = collections.defaultdict(list)
        for i, val in enumerate(nums):
            temp = val
            while temp > 1:
                p = spf[temp]
                bucket[p].append(i)
                while temp % p == 0:
                    temp //= p
        
        queue = collections.deque([(0, 0)]) 
        visited_idx = {0}
        visited_primes = set()
        
        while queue:
            curr, dist = queue.popleft()
            
            if curr == n - 1:
                return dist
            
            for neighbor in [curr - 1, curr + 1]:
                if 0 <= neighbor < n and neighbor not in visited_idx:
                    visited_idx.add(neighbor)
                    queue.append((neighbor, dist + 1))
            
            p = nums[curr]
            if is_prime(p) and p not in visited_primes:
                visited_primes.add(p)
                for neighbor in bucket[p]:
                    if neighbor not in visited_idx:
                        visited_idx.add(neighbor)
                        queue.append((neighbor, dist + 1))
                bucket[p] = []
                
        return -1 
